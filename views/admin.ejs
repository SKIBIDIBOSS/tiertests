<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>ADMIN | SKIBIDIBOSS</title>
    <style>
        body { background: #0b0c0e; color: #fff; font-family: sans-serif; padding: 50px; }
        .panel { background: #18191c; padding: 30px; border-radius: 15px; border: 1px solid #ff4757; }
        input, select, button { padding: 12px; margin: 5px; border-radius: 5px; border: 1px solid #333; background: #000; color: #fff; }
        button { background: #ff4757; border: none; font-weight: bold; cursor: pointer; }
        table { width: 100%; margin-top: 30px; border-collapse: collapse; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #222; }
    </style>
</head>
<body>
    <div class="panel">
        <h1 style="color: #ff4757; margin-top: 0;">ADMIN COMMAND</h1>
        <form action="/admin/action" method="POST">
            <input type="hidden" name="action" value="create">
            <input type="text" name="username" placeholder="Username" required>
            <select name="tier">
                <option value="HT1">HT1</option>
                <option value="LT1">LT1</option>
                <option value="HT2">HT2</option>
                <option value="LT2">LT2</option>
                <option value="Unranked">Unranked</option>
            </select>
            <select name="role">
                <option value="user">User</option>
                <option value="tester">Tester</option>
                <option value="admin">Admin</option>
            </select>
            <button type="submit">CREATE PLAYER</button>
        </form>

        <table>
            <thead><tr><th>NAME</th><th>RANK</th><th>ACTION</th></tr></thead>
            <tbody>
                <% users.forEach(user => { %>
                    <tr>
                        <td><%= user.username %></td>
                        <td><%= user.tier %></td>
                        <td>
                            <form action="/admin/action" method="POST">
                                <input type="hidden" name="action" value="delete">
                                <input type="hidden" name="userId" value="<%= user._id %>">
                                <button type="submit" style="padding: 5px 10px; font-size: 0.7rem;">REMOVE</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <br><a href="/" style="color: #555;">Return to Hub</a>
</body>
</html>
