<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SECURE LOGIN | SKIBIDIBOSS</title>
    <style>
        body { background: #090a0b; color: #fff; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .login-box { background: #18191c; padding: 40px; border-radius: 15px; text-align: center; border: 1px solid #00d1ff; width: 300px; }
        input { width: 100%; padding: 12px; margin: 10px 0; background: #000; border: 1px solid #333; color: #fff; box-sizing: border-box; border-radius: 5px; }
        button { width: 100%; padding: 12px; background: #00d1ff; border: none; font-weight: bold; cursor: pointer; border-radius: 5px; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="login-box">
        <h2 style="color: #00d1ff; margin-bottom: 20px;">HUB ACCESS</h2>
        <% if (error) { %><p style="color: #ff4757;"><%= error %></p><% } %>
        <form action="/login" method="POST">
            <input type="text" name="username" placeholder="Username" required>
            <input type="password" name="password" placeholder="Password" required>
            <button type="submit">LOG IN</button>
        </form>
    </div>
</body>
</html>
