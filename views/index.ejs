<!DOCTYPE html>
<html>
<head>
    <title>SKIBIDIBOSS X LINING</title>
    <style>
        :root { --bg: #0b0c0e; --side: #121417; --accent: #00d1ff; }
        body { background: var(--bg); color: white; font-family: 'Inter', sans-serif; display: flex; margin: 0; height: 100vh; }
        .sidebar { width: 260px; background: var(--side); padding: 20px; border-right: 1px solid #222; }
        .main { flex: 1; padding: 40px; overflow-y: auto; }
        .forum { width: 300px; background: var(--side); border-left: 1px solid #222; display: flex; flex-direction: column; }
        .player-row { background: #1c1e22; padding: 15px; border-radius: 8px; margin-bottom: 10px; display: flex; align-items: center; justify-content: space-between; }
        .icon { width: 24px; margin-left: 5px; vertical-align: middle; }
        .btn-test { background: var(--accent); color: black; padding: 12px; border-radius: 5px; text-decoration: none; font-weight: bold; display: block; text-align: center; }
    </style>
</head>
<body>
    <div class="sidebar">
        <h2>SKIBIDIBOSS X</h2>
        <a href="/" style="color:white; text-decoration:none;">Leaderboard</a><br><br>
        <% if (user) { %>
            <p>Logged as: <%= user.username %></p>
            <a href="/logout" style="color:#555;">Logout</a>
        <% } else { %>
            <a href="/login" class="btn-test">Staff Login</a>
        <% } %>
    </div>

    <div class="main">
        <h1>Leaderboard</h1>
        <div class="player-row" style="border: 1px solid gold;">
            <span>1. <b>lining</b> (lining123) ⚔️🛡️🏹</span>
            <span>Sumo: LT2 | Bedfight: HT2 | Classic: HT3</span>
        </div>
        <% players.forEach((p, i) => { %>
            <div class="player-row">
                <span><%= i+2 %>. <img src="<%= p.pfp %>" width="20"> <b><%= p.username %></b></span>
                <span>S: <%= p.ranks.sumo %> | B: <%= p.ranks.bedfight %></span>
            </div>
        <% }) %>
        <br>
        <div style="background:#1c1e22; padding: 20px; border-radius: 10px; text-align: center;">
            <h3>Want to join? Get tested now</h3>
            <button onclick="document.getElementById('qModal').style.display='block'" class="btn-test">JOIN QUEUE</button>
        </div>
    </div>

    <div class="forum">
        <div style="padding:15px; border-bottom:1px solid #222;">Public Forum</div>
        <div style="flex:1; padding:10px; font-size: 0.8rem;">
            <% chat.forEach(m => { %>
                <div><b><%= m.username %>:</b> <%= m.text %></div>
            <% }) %>
        </div>
    </div>

    <div id="qModal" style="display:none; position:fixed; background:rgba(0,0,0,0.8); width:100%; height:100%; top:0; left:0; padding:100px;">
        <div style="background:#1c1e22; padding:30px; width:400px; margin:auto; border-radius:10px;">
            <form action="/queue/join" method="POST">
                <input type="text" name="ign" placeholder="Minecraft IGN" required><br><br>
                <input type="text" name="timezone" placeholder="Timezone (EST/GMT)" required><br><br>
                <select name="server"><option>NA</option><option>EU</option><option>AS</option></select><br><br>
                <button type="submit" class="btn-test">Submit Application</button>
            </form>
        </div>
    </div>
</body>
</html>
