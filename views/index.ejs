<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HUB | COMPETITIVE OPERATIONS</title>
    <style>
        :root {
            --bg: #0b0c0e;
            --sidebar: #121417;
            --accent: #00d1ff;
            --accent-glow: rgba(0, 209, 255, 0.3);
            --card: #1c1e22;
            --text-main: #ffffff;
            --text-dim: #8e9297;
        }

        body {
            margin: 0;
            background-color: var(--bg);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            display: grid;
            grid-template-columns: 280px 1fr 320px; /* Sidebar | Main | Chat */
            height: 100vh;
            overflow: hidden;
        }

        /* --- SIDEBAR --- */
        .sidebar {
            background: var(--sidebar);
            border-right: 1px solid rgba(255,255,255,0.05);
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
        }

        .logo {
            font-size: 1.8rem;
            font-weight: 900;
            letter-spacing: -1px;
            margin-bottom: 50px;
            background: linear-gradient(to bottom, #fff, var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-link {
            padding: 14px 18px;
            color: var(--text-dim);
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 8px;
            font-weight: 600;
            transition: 0.2s;
        }

        .nav-link:hover, .nav-link.active {
            background: rgba(255,255,255,0.05);
            color: #fff;
            box-shadow: inset 4px 0 0 var(--accent);
        }

        .btn-test {
            margin-top: auto;
            background: linear-gradient(45deg, var(--accent), #5865f2);
            padding: 20px;
            border-radius: 14px;
            text-align: center;
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }

        /* --- MAIN CONTENT --- */
        main { padding: 50px; overflow-y: auto; }

        .glow-title {
            font-size: 3.5rem;
            text-transform: uppercase;
            margin: 0;
            text-shadow: 0 0 20px var(--accent-glow);
        }

        .slogan { color: var(--text-dim); letter-spacing: 3px; margin-bottom: 40px; }

        .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 40px; }
        .stat-box { background: var(--card); padding: 25px; border-radius: 15px; border: 1px solid rgba(255,255,255,0.03); }
        .stat-box label { color: var(--text-dim); font-size: 0.75rem; text-transform: uppercase; }
        .stat-box div { font-size: 1.8rem; font-weight: 800; color: var(--accent); }

        .rank-table {
            width: 100%;
            background: var(--card);
            border-radius: 15px;
            border-collapse: collapse;
        }

        .rank-table th { text-align: left; padding: 20px; color: var(--text-dim); font-size: 0.8rem; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .rank-table td { padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.02); }

        .tier-badge {
            background: #000;
            border: 1px solid var(--accent);
            padding: 5px 12px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: bold;
        }

        /* --- CHAT --- */
        .chat-area {
            background: var(--sidebar);
            border-left: 1px solid rgba(255,255,255,0.05);
            display: flex;
            flex-direction: column;
        }

        .chat-head { padding: 30px; font-weight: 800; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .messages { flex: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 15px; }
        .msg-item { font-size: 0.9rem; border-left: 2px solid var(--accent); padding-left: 10px; }
        .msg-item b { color: var(--accent); display: block; }
        
        .chat-input {
            margin: 20px;
            padding: 15px;
            background: #1e2024;
            border: none;
            border-radius: 8px;
            color: white;
        }

        /* Role Colors */
        .admin { color: #ff4757; }
        .tester { color: #1e90ff; }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="logo">CORE_HUB</div>
        <a href="/" class="nav-link active">Leaderboard</a>
        <a href="#" class="nav-link">Live Queues</a>
        <a href="#" class="nav-link">Community Forum</a>
        <a href="#" class="nav-link">My Profile</a>
        <a href="/admin" class="nav-link" style="opacity: 0.3;">System Admin</a>

        <div class="btn-test">
            GET TESTED
            <div style="font-size: 0.6rem; font-weight: 400;">Apply for Tier Ranking</div>
        </div>
    </div>

    <main>
        <h1 class="glow-title">Rankings</h1>
        <div class="slogan">OFFICIAL COMPETITIVE OPERATIONS DATA</div>

        <div class="stats-row">
            <div class="stat-box"><label>Operatives</label><div><%= stats.active %></div></div>
            <div class="stat-box"><label>In Queue</label><div><%= stats.queuing %></div></div>
            <div class="stat-box"><label>System</label><div style="color: #4cd137;"><%= stats.status %></div></div>
        </div>

        <table class="rank-table">
            <thead>
                <tr>
                    <th>IDENTITY</th>
                    <th>RANKING</th>
                    <th>PROFILE</th>
                </tr>
            </thead>
            <tbody>
                <% if (users.length > 0) { %>
                    <% users.forEach(user => { %>
                        <tr>
                            <td class="<%= user.role %>" style="font-weight: 700;"><%= user.username %></td>
                            <td><span class="tier-badge"><%= user.tier %></span></td>
                            <td><a href="#" style="color: var(--accent); text-decoration: none; font-size: 0.8rem;">OPEN DATA</a></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="3" style="text-align: center; color: var(--text-dim); padding: 40px;">No players synced. Visit Admin to add users.</td></tr>
                <% } %>
            </tbody>
        </table>
    </main>

    <div class="chat-area">
        <div class="chat-head"># GLOBAL_CHAT</div>
        <div class="messages">
            <div class="msg-item"><b>System</b>Connect successful. Monitoring communications.</div>
            <div class="msg-item"><b>Ghost_99</b>Anyone up for LT1 testing?</div>
            <div class="msg-item"><b>Staff_Rex</b>Server maintenance in 2 hours.</div>
        </div>
        <input type="text" class="chat-input" placeholder="Secure message...">
    </div>

</body>
</html>
