<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SKIBIDIBOSS X LINING</title>
    <style>
        :root { --bg: #090a0b; --side: #111214; --accent: #00d1ff; --card: #18191c; --green: #2ecc71; }
        body { margin: 0; background: var(--bg); color: #fff; font-family: 'Inter', sans-serif; display: flex; height: 100vh; }
        
        /* SIDEBAR LOGIC */
        .sidebar { width: 280px; background: var(--side); border-right: 1px solid #222; display: flex; flex-direction: column; padding: 25px; }
        .nav-item { padding: 12px; color: #8e9297; text-decoration: none; border-radius: 8px; margin-bottom: 5px; font-weight: 600; display: block; transition: 0.2s; }
        .nav-item:hover { background: #222; color: #fff; }
        .nav-item.active { border-left: 3px solid var(--accent); color: #fff; }

        .profile-box { margin-top: auto; padding: 15px; background: #1e1f22; border-radius: 12px; }
        
        /* MAIN UI */
        .main { flex: 1; padding: 40px; overflow-y: auto; }
        .status-light { display: flex; align-items: center; background: var(--card); padding: 15px; border-radius: 10px; margin: 20px 0; border: 1px solid #222; }
        .glow { width: 10px; height: 10px; background: var(--green); border-radius: 50%; box-shadow: 0 0 10px var(--green); margin-right: 15px; }

        /* INTERACTIVE QUEUE */
        .queue-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
        .q-card { background: var(--card); border-radius: 12px; overflow: hidden; border: 1px solid #333; cursor: pointer; transition: 0.3s; }
        .q-card:hover { transform: translateY(-5px); border-color: var(--accent); }
        .q-img { height: 120px; background-size: cover; background-position: center; }
        .q-info { padding: 15px; text-align: center; }
        .q-btn { background: var(--accent); color: #000; border: none; width: 100%; padding: 10px; font-weight: bold; border-radius: 6px; cursor: pointer; }
    </style>
</head>
<body>

    <nav class="sidebar">
        <div style="font-weight: 900; color: var(--accent); margin-bottom: 30px; letter-spacing: 2px;">SKIBIDIBOSS X LINING</div>
        
        <a href="/" class="nav-item active">🏠 Leaderboard</a>
        <a href="#" class="nav-item">💬 Global Forum</a>
        <a href="#" class="nav-item">⚔️ Active Queues</a>

        <% if (user) { %>
            <hr style="border:0; border-top:1px solid #333; margin: 20px 0;">
            
            <% if (user.role === 'admin') { %>
                <div style="color: #ff4757; font-size: 0.7rem; font-weight: 800;">ADMIN TOOLS</div>
                <a href="/admin" class="nav-item">🛠️ Manage Staff</a>
                <a href="#" class="nav-item">🎫 View Tickets</a>
            <% } %>

            <% if (user.role === 'tester') { %>
                <div style="color: var(--accent); font-size: 0.7rem; font-weight: 800;">TESTER TOOLS</div>
                <a href="#" class="nav-item">📋 Pending Tests</a>
                <a href="#" class="nav-item">📝 Log Score</a>
            <% } %>

            <div class="profile-box">
                <div style="font-size: 0.8rem; color: #8e9297;">Account</div>
                <div style="font-weight: bold;"><%= user.username %></div>
                <a href="/logout" style="color: #ff4757; font-size: 0.7rem; text-decoration: none;">Sign Out</a>
            </div>
        <% } %>
    </nav>

    <main class="main">
        <h1>Global Ranking</h1>
        <div style="background: var(--card); padding: 10px; border-radius: 12px;">
            <div style="padding: 15px; border-left: 4px solid var(--accent); background: rgba(0,209,255,0.05); margin-bottom: 5px;">
                <b>lining</b> <span style="float: right;">LT2 | HT2 | HT3</span>
            </div>
            <div style="padding: 15px; border-bottom: 1px solid #222;">
                <b>skibidiboss</b> <span style="float: right;">LT3 | LT3 | Unrated</span>
            </div>
        </div>

        <div class="status-light">
            <div class="glow"></div>
            <span>Want to get tested? <a href="/signup" style="color: var(--accent);">Sign up</a> or <a href="/login" style="color: var(--accent);">Login</a></span>
        </div>

        <h2>Select Game Mode</h2>
        <div class="queue-grid">
            <div class="q-card" onclick="alert('Joined Sumo Queue!')">
                <div class="q-img" style="background-image: url('https://i.imgur.com/8QG9v2S.png');"></div> <div class="q-info">
                    <b>SUMO</b>
                    <button class="q-btn">JOIN</button>
                </div>
            </div>
            <div class="q-card" onclick="alert('Joined Bedfight Queue!')">
                <div class="q-img" style="background-image: url('https://i.imgur.com/L1ZzZ6U.png');"></div> <div class="q-info">
                    <b>BEDFIGHT</b>
                    <button class="q-btn">JOIN</button>
                </div>
            </div>
        </div>
    </main>

</body>
</html>
