<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HUB | COMPETITIVE OPERATIONS</title>
    <style>
        :root {
            --primary: #5865f2;
            --glow: #7289da;
            --bg: #090a0b;
            --sidebar-bg: #111214;
            --card-bg: #18191c;
            --accent: #00d1ff;
            --text: #ffffff;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            margin: 0;
            display: grid;
            grid-template-columns: 260px 1fr 300px; /* Sidebar | Content | Chat */
            height: 100vh;
            overflow: hidden;
        }

        /* --- SIDEBAR --- */
        nav {
            background: var(--sidebar-bg);
            border-right: 1px solid rgba(255,255,255,0.05);
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .logo { font-size: 1.5rem; font-weight: 800; margin-bottom: 40px; color: var(--accent); text-shadow: 0 0 10px var(--accent); }
        
        .nav-item {
            padding: 12px 15px;
            border-radius: 8px;
            color: #8e9297;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
        }

        .nav-item:hover, .nav-item.active { background: rgba(255,255,255,0.05); color: #fff; box-shadow: inset 4px 0 0 var(--accent); }

        .get-tested-box {
            margin-top: auto;
            background: linear-gradient(45deg, #5865f2, #00d1ff);
            padding: 15px;
            border-radius: 12px;
            text-align: center;
            font-size: 0.85rem;
            font-weight: bold;
            cursor: pointer;
        }

        /* --- MAIN CONTENT --- */
        main { padding: 40px; overflow-y: auto; }
        
        .header-section { margin-bottom: 30px; }
        h1 { font-size: 2.2rem; text-transform: uppercase; letter-spacing: -1px; }
        
        .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: var(--card-bg); padding: 20px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); }
        .stat-card small { color: #8e9297; text-transform: uppercase; font-size: 0.7rem; }
        .stat-card div { font-size: 1.5rem; font-weight: bold; margin-top: 5px; color: var(--accent); }

        .leaderboard-table {
            width: 100%;
            background: var(--card-bg);
            border-radius: 12px;
            border-collapse: collapse;
            overflow: hidden;
        }

        .leaderboard-table th { background: rgba(0,0,0,0.2); padding: 15px; text-align: left; color: #8e9297; font-size: 0.8rem; }
        .leaderboard-table td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.03); }

        .tier-tag { padding: 4px 10px; border-radius: 6px; background: #2f3136; border: 1px solid var(--accent); font-size: 0.75rem; }

        /* --- CHAT/FORUM SIDEBAR --- */
        aside {
            background: var(--sidebar-bg);
            border-left: 1px solid rgba(255,255,255,0.05);
            display: flex;
            flex-direction: column;
        }

        .chat-header { padding: 20px; border-bottom: 1px solid rgba(255,255,255,0.05); font-weight: bold; }
        .chat-messages { flex: 1; padding: 20px; display: flex; flex-direction: column; gap: 15px; overflow-y: auto; }
        .msg { font-size: 0.85rem; }
        .msg b { color: var(--accent); display: block; margin-bottom: 2px; }
        .msg p { margin: 0; color: #dcddde; }

        .chat-input { padding: 20px; background: #1e1f22; border: none; color: white; width: 100%; box-sizing: border-box; }
    </style>
</head>
<body>

    <nav>
        <div class="logo">OPERATIONS</div>
        <a href="/" class="nav-item active">Leaderboard</a>
        <a href="/queues" class="nav-item">Matchmaking Queues</a>
        <a href="/forum" class="nav-item">Forum/Discussions</a>
        <a href="/profile" class="nav-item">My Profile</a>
        <a href="/admin" class="nav-item" style="margin-top: 20px; opacity: 0.5;">Staff Panel</a>
        
        <div class="get-tested-box">
            GET TESTED NOW
            <div style="font-size: 0.7rem; font-weight: normal; opacity: 0.8;">Apply for Rank Assessment</div>
        </div>
    </nav>

    <main>
        <div class="header-section">
            <h1>Global Leaderboard</h1>
            <p style="color: #8e9297;">Live rankings for the current competitive season.</p>
        </div>

        <div class="stats-grid">
            <div class="stat-card"><small>Active Users</small><div><%= users.length %></div></div>
            <div class="stat-card"><small>In Queue</small><div>12 Players</div></div>
            <div class="stat-card"><small>Server Status</small><div style="color: #43b581;">Online</div></div>
        </div>

        <table class="leaderboard-table">
            <thead>
                <tr>
                    <th>PLAYER IDENTITY</th>
                    <th>RANKING</th>
                    <th>STATUS</th>
                </tr>
            </thead>
            <tbody>
                <% if (users.length > 0) { %>
                    <% users.forEach(user => { %>
                        <tr>
                            <td style="font-weight: bold;"><%= user.username %></td>
                            <td><span class="tier-tag"><%= user.tier %></span></td>
                            <td><a href="/profile/<%= user._id %>" style="color: var(--accent); text-decoration: none; font-size: 0.8rem;">VIEW PROFILE</a></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="3" style="text-align: center; padding: 40px; color: #8e9297;">No records found. Syncing database...</td></tr>
                <% } %>
            </tbody>
        </table>
    </main>

    <aside>
        <div class="chat-header">COMMUNITY CHAT</div>
        <div class="chat-messages">
            <div class="msg"><b>System</b><p>Welcome to the Hub. Type /help for commands.</p></div>
            <div class="msg"><b>User_42</b><p>Looking for LT1 scrims tonight!</p></div>
            <div class="msg"><b>Staff_Alpha</b><p>Rank resets happening in 48 hours.</p></div>
        </div>
        <input type="text" class="chat-input" placeholder="Message #global...">
    </aside>

</body>
</html>
