<!DOCTYPE html>
<html>
<head>
    <title>SKIBIDIBOSS X LINING</title>
    <style>
        body { background: #0b0c0e; color: white; font-family: sans-serif; margin: 0; display: flex; }
        .sidebar { width: 250px; background: #121417; height: 100vh; padding: 20px; border-right: 1px solid #222; }
        .content { flex: 1; padding: 50px; }
        .tier-card { background: #1c1e22; padding: 20px; border-radius: 10px; margin-bottom: 10px; display: flex; justify-content: space-between; }
        .btn-test { background: #00d1ff; color: black; padding: 15px; border-radius: 8px; text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>
    <div class="sidebar">
        <h2>SKIBIDIBOSS X</h2>
        <a href="/" style="color:white; display:block; margin: 10px 0;">Leaderboard</a>
        <a href="/queue" style="color:white; display:block; margin: 10px 0;">Join Queue</a>
        <% if (user && user.role === 'admin') { %>
            <a href="/admin" style="color:red; display:block; margin: 10px 0;">Admin Panel</a>
        <% } %>
    </div>
    <div class="content">
        <h1>Leaderboard</h1>
        <div class="leaderboard">
            <% players.forEach(player => { %>
                <div class="tier-card">
                    <span><img src="<%= player.pfp %>" width="30"> <b><%= player.username %></b> (<%= player.ign %>)</span>
                    <span>Sumo: <%= player.ranks.sumo %> | Bedfight: <%= player.ranks.bedfight %></span>
                </div>
            <% }) %>
        </div>
        <br><br>
        <h3>Want to join? Get tested now</h3>
        <a href="/queue" class="btn-test">GET TESTED NOW</a>
    </div>
</body>
</html>
