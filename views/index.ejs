<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SKIBIDIBOSS X LINING TIERS</title>
    <style>
        :root { --bg: #090a0b; --sidebar: #111214; --accent: #00d1ff; --card: #18191c; --text: #ffffff; }
        body { margin: 0; background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; display: grid; grid-template-columns: 260px 1fr 300px; height: 100vh; overflow: hidden; }
        
        nav { background: var(--sidebar); padding: 30px 20px; display: flex; flex-direction: column; border-right: 1px solid #222; }
        .logo { font-size: 1.2rem; font-weight: 900; color: var(--accent); margin-bottom: 40px; text-transform: uppercase; letter-spacing: 1px; }
        .nav-link { padding: 12px; color: #8e9297; text-decoration: none; font-weight: 600; border-radius: 8px; margin-bottom: 5px; transition: 0.2s; }
        .nav-link:hover { background: #222; color: #fff; }
        .btn-test { margin-top: auto; background: var(--accent); color: #000; padding: 15px; border-radius: 10px; text-align: center; font-weight: 800; text-decoration: none; box-shadow: 0 0 15px rgba(0,209,255,0.3); }

        main { padding: 40px; overflow-y: auto; }
        .glow-h1 { font-size: 3rem; margin: 0; text-shadow: 0 0 20px rgba(0,209,255,0.4); text-transform: uppercase; }
        .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 30px 0; }
        .stat-card { background: var(--card); padding: 20px; border-radius: 12px; border: 1px solid #333; }
        
        table { width: 100%; background: var(--card); border-radius: 12px; border-collapse: collapse; }
        th { text-align: left; padding: 15px; color: #8e9297; border-bottom: 1px solid #333; font-size: 0.8rem; }
        td { padding: 15px; border-bottom: 1px solid #222; }
        .tier-badge { border: 1px solid var(--accent); padding: 4px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: bold; }

        aside { background: var(--sidebar); border-left: 1px solid #222; display: flex; flex-direction: column; }
        .chat-head { padding: 20px; font-weight: bold; border-bottom: 1px solid #222; letter-spacing: 1px; }
        .messages { flex: 1; padding: 15px; overflow-y: auto; font-size: 0.85rem; display: flex; flex-direction: column; gap: 10px; }
        .chat-input { padding: 20px; background: #1e1f22; border: none; color: #fff; outline: none; }
    </style>
</head>
<body>
    <nav>
        <div class="logo">SKIBIDIBOSS X</div>
        <a href="/" class="nav-link">Leaderboard</a>
        <a href="#" class="nav-link">Live Queues</a>
        <a href="#" class="nav-link">Forum</a>
        <a href="/tester" class="nav-link" style="margin-top: 20px; color: #5865f2;">Tester Terminal</a>
        <a href="/admin" class="nav-link" style="opacity: 0.2;">Admin</a>
        <a href="#" class="btn-test">GET TESTED</a>
    </nav>

    <main>
        <h1 class="glow-h1">Lining Tiers</h1>
        <p style="color: #8e9297; letter-spacing: 2px; font-size: 0.8rem;">CORE OPERATIONS CENTER</p>
        
        <div class="stats">
            <div class="stat-card"><small>TOTAL OPERATIVES</small><div style="font-size: 1.5rem; font-weight: bold; color: var(--accent);"><%= users.length %></div></div>
            <div class="stat-card"><small>IN QUEUE</small><div style="font-size: 1.5rem; font-weight: bold; color: var(--accent);">14</div></div>
            <div class="stat-card"><small>SYSTEM STATUS</small><div style="font-size: 1.5rem; font-weight: bold; color: #4cd137;">ACTIVE</div></div>
        </div>

        <table>
            <thead><tr><th>OPERATIVE</th><th>TIER</th><th>DATA</th></tr></thead>
            <tbody>
                <% users.forEach(user => { %>
                    <tr>
                        <td style="font-weight: bold;"><%= user.username %></td>
                        <td><span class="tier-badge"><%= user.tier %></span></td>
                        <td><a href="#" style="color: var(--accent); text-decoration: none; font-size: 0.8rem;">View Profile</a></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </main>

    <aside>
        <div class="chat-head"># GLOBAL_CHAT</div>
        <div class="messages">
            <div><b style="color: var(--accent);">System:</b> Connection established.</div>
            <div><b style="color: #5865f2;">Staff:</b> New LT1 tests starting now.</div>
        </div>
        <input type="text" class="chat-input" placeholder="Type a message...">
    </aside>
</body>
</html>
