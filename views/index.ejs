<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SKIBIDIBOSS X LINING | TIER HUB</title>
    <style>
        :root {
            --bg: #090a0b;
            --sidebar: #111214;
            --card: #18191c;
            --accent: #00d1ff;
            --text: #ffffff;
            --muted: #8e9297;
        }
        body { margin: 0; background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; display: flex; height: 100vh; overflow: hidden; }

        /* SIDEBAR */
        .sidebar { width: 260px; background: var(--sidebar); border-right: 1px solid #222; display: flex; flex-direction: column; padding: 25px; }
        .logo { font-size: 1.2rem; font-weight: 800; color: var(--accent); margin-bottom: 40px; letter-spacing: 1px; }
        .nav-item { padding: 12px; color: var(--muted); text-decoration: none; border-radius: 8px; margin-bottom: 5px; font-weight: 600; display: flex; align-items: center; }
        .nav-item:hover, .active { background: #222; color: #fff; }
        
        /* MAIN CONTENT */
        .main { flex: 1; padding: 40px; overflow-y: auto; }
        .leaderboard-table { width: 100%; border-collapse: collapse; background: var(--card); border-radius: 12px; overflow: hidden; }
        .leaderboard-table th { text-align: left; padding: 15px; color: var(--muted); background: rgba(0,0,0,0.2); }
        .leaderboard-table td { padding: 15px; border-bottom: 1px solid #222; }
        .lining-row { border-left: 4px solid var(--accent); background: rgba(0,209,255,0.05); }

        /* STATUS SECTION */
        .auth-prompt { margin-top: 30px; padding: 20px; background: var(--card); border-radius: 12px; display: flex; align-items: center; }
        .glow-dot { width: 10px; height: 10px; background: #2ecc71; border-radius: 50%; box-shadow: 0 0 10px #2ecc71; margin-right: 15px; }

        /* DISCORD FORUM */
        .forum { width: 320px; background: var(--sidebar); border-left: 1px solid #222; display: flex; flex-direction: column; }
        .chat-header { padding: 20px; font-weight: 700; border-bottom: 1px solid #222; }
        .messages { flex: 1; padding: 15px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }
        .msg { font-size: 0.9rem; }
        .msg.admin { color: #ff4757; }
        .msg.tester { color: #00d1ff; }
        .msg.user { color: #ffffff; }
        .chat-input { padding: 15px; background: #1e1f22; border: none; color: white; width: 100%; box-sizing: border-box; }

        /* QUEUE CARDS */
        .queue-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 20px; }
        .q-card { background: var(--card); padding: 15px; border-radius: 10px; text-align: center; border: 1px solid #333; }
        .q-card img { width: 100%; height: 80px; object-fit: cover; border-radius: 5px; margin-bottom: 10px; }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="logo">SKIBIDIBOSS X LINING</div>
        <a href="/" class="nav-item active">🏠 Home</a>
        <a href="#" class="nav-item">💬 Forum</a>
        <a href="#" class="nav-item">⚔️ Join Queue</a>
        
        <div style="margin-top: auto;">
            <% if (!user) { %>
                <form action="/login" method="POST">
                    <input type="text" name="username" placeholder="Username" style="width:100%; padding:8px; margin-bottom:5px; background:#000; border:1px solid #333; color:#fff;">
                    <input type="password" name="password" placeholder="Password" style="width:100%; padding:8px; margin-bottom:10px; background:#000; border:1px solid #333; color:#fff;">
                    <button style="width:100%; background:var(--accent); color:#000; border:none; padding:10px; font-weight:bold; border-radius:5px;">Login</button>
                </form>
            <% } else { %>
                <div style="color:var(--accent)">Logged in as <%= user.username %></div>
            <% } %>
        </div>
    </div>

    <div class="main">
        <h1>Global Leaderboard</h1>
        <table class="leaderboard-table">
            <thead>
                <tr><th>Player</th><th>Sumo</th><th>Bedfight</th><th>Classic</th></tr>
            </thead>
            <tbody>
                <tr class="lining-row">
                    <td><b>lining</b> ⚔️</td><td>LT2</td><td>HT2</td><td>HT3</td>
                </tr>
                <tr>
                    <td><b>skibidiboss</b></td><td>LT3</td><td>LT3</td><td>Unrated</td>
                </tr>
                <% players.forEach(p => { %>
                    <tr>
                        <td><%= p.username %></td><td><%= p.ranks.sumo %></td><td><%= p.ranks.bedfight %></td><td><%= p.ranks.classic %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <div class="auth-prompt">
            <div class="glow-dot"></div>
            <span>Want to get tested? <a href="#" style="color:var(--accent)">Sign up</a> or already have an account? <a href="#" style="color:var(--accent)">Login</a></span>
        </div>

        <h2 style="margin-top:40px;">Active Queues</h2>
        <div class="queue-grid">
            <div class="q-card">
                <img src="https://i.imgur.com/8QG9v2S.png" alt="Sumo">
                <b>Sumo 1v1</b>
                <button style="display:block; width:100%; margin-top:10px; background:#222; color:#fff; border:none; padding:8px; border-radius:4px;">Join Queue</button>
            </div>
            <div class="q-card">
                <img src="https://i.imgur.com/L1ZzZ6U.png" alt="Bedfight">
                <b>Bedfight 1v1</b>
                <button style="display:block; width:100%; margin-top:10px; background:#222; color:#fff; border:none; padding:8px; border-radius:4px;">Join Queue</button>
            </div>
        </div>
    </div>

    <div class="forum">
        <div class="chat-header">FORUM DISCUSSION</div>
        <div class="messages">
            <% chat.forEach(m => { %>
                <div class="msg <%= m.role %>">
                    <b style="font-size: 0.75rem; display:block;"><%= m.username %></b>
                    <%= m.text %>
                </div>
            <% }) %>
        </div>
        <% if (user) { %>
            <form action="/chat/send" method="POST">
                <input type="text" name="text" class="chat-input" placeholder="Message #global...">
            </form>
        <% } %>
    </div>

</body>
</html>
